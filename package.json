  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.304",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@wxt-dev/module-react": "^1.1.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wxt": "^0.19.0"
  },
  "packageManager": "pnpm@9.15.0"
}
